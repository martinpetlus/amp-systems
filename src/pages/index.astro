---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "../i18n/ui";
import { servicesContent } from "../i18n/services";
import { routes } from "../i18n/routes";

const t = useTranslations("sk");
const services = servicesContent.sk;
const servicesHref = getRelativeLocaleUrl("sk", routes.services.sk);
const contactHref = getRelativeLocaleUrl("sk", routes.contact.sk);
---

<BaseLayout>
  <h1 class="text-4xl font-bold tracking-tight">{t("hero.title")}</h1>
  <p class="mt-4 text-lg text-slate-600">{t("hero.subtitle")}</p>

  <div class="mt-8 flex flex-wrap gap-3">
    <a
      href={contactHref}
      class="inline-flex items-center gap-1 rounded-lg bg-slate-900 px-5 py-2.5 font-medium text-white transition hover:bg-slate-700"
    >
      {t("nav.contact")}
      <span aria-hidden="true">→</span>
    </a>
    <a
      href={servicesHref}
      class="inline-flex items-center rounded-lg border border-slate-300 px-5 py-2.5 font-medium text-slate-700 transition hover:bg-slate-100"
    >
      {t("nav.services")}
    </a>
  </div>

  <section class="mt-16">
    <h2 class="text-2xl font-bold tracking-tight">{services.title}</h2>
    <p class="mt-2 text-slate-600">{services.intro}</p>
    <div class="mt-6">
      <ServicesGrid lang="sk" />
    </div>
    <a
      href={servicesHref}
      class="mt-6 inline-flex items-center gap-1 font-medium text-sky-600 hover:text-sky-800"
    >
      {t("services.home.cta")}
      <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
